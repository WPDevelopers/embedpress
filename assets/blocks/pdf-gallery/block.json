{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "title": "EmbedPress PDF Gallery",
  "name": "embedpress/pdf-gallery",
  "category": "embedpress",
  "description": "Display multiple PDF documents in a gallery layout with grid, masonry, or carousel options. Click to open in a popup viewer.",
  "apiVersion": 3,
  "textdomain": "embedpress",
  "editorScript": "embedpress-blocks-editor",
  "editorStyle": "embedpress-blocks-editor-style",
  "style": "embedpress-blocks-style",
  "supports": {
    "align": ["left", "center", "right", "wide", "full"],
    "html": false,
    "anchor": true,
    "lightBlockWrapper": true,
    "default": "center"
  }
}
